{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": "ask"
  },
  "provider": {
    "openai": {
      "options": {
        "baseURL": "https://api.duckcoding.ai/v1"
      }
    }
  },
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  }
}
